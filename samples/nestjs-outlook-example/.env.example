# Microsoft OAuth Configuration
# Get these values from Azure Portal > App Registrations
MICROSOFT_CLIENT_ID=your-azure-app-client-id
MICROSOFT_CLIENT_SECRET=your-azure-app-client-secret

# Backend Configuration
# The base URL where your NestJS application is running.
#
# localhost works only for flows that never leave your machine. Microsoft Graph
# cannot reach localhost, so to exercise the real OAuth callback or receive webhook
# notifications you need a public HTTPS URL. Use the fixed zrok tunnel (see ZROK.md):
#   1. zrok2 create name nestjs-outlook-demo   (once)
#   2. npm run zrok:share                       (bridges the tunnel -> :8888 per run)
#   3. set BACKEND_BASE_URL to the zrok URL below and register it in Azure
# BACKEND_BASE_URL=https://nestjs-outlook-demo.shares.zrok.io
BACKEND_BASE_URL=http://localhost:8888

# Microsoft OAuth Routes Configuration
# The path where Microsoft will redirect after authentication
MICROSOFT_REDIRECT_PATH=auth/microsoft/callback
# The base path for all API routes
MICROSOFT_BASE_PATH=api/v1

# ============================================================
# App-Only Authentication (Tenant-Wide Access)
# ============================================================
# Enable this for background services or admin operations that need
# tenant-wide access without user delegation.
# Uses OAuth 2.0 client credentials flow.

# Set to "true" to enable app-only authentication
MICROSOFT_APP_ONLY_ENABLED=false

# Azure AD Tenant ID (required when app-only is enabled)
# Format: GUID (e.g., 12345678-1234-1234-1234-123456789abc)
# Find this in Azure Portal > Azure Active Directory > Overview
MICROSOFT_TENANT_ID=your-azure-tenant-id

# ============================================================
# Certificate Authentication (Optional, Recommended for Production)
# ============================================================
# More secure than client secret. The certificate must be registered
# in Azure AD under "Certificates & secrets" > "Certificates".

# Certificate thumbprint (SHA-256 hash, base64url-encoded)
# Find this in Azure Portal > App Registration > Certificates & secrets
# MICROSOFT_CERTIFICATE_THUMBPRINT=your-certificate-thumbprint

# Private key - provide ONE of these options:
# Option 1: Path to PEM file
# MICROSOFT_PRIVATE_KEY_PATH=/path/to/private-key.pem

# Option 2: Base64-encoded PEM (useful for environment variables)
# MICROSOFT_PRIVATE_KEY_BASE64=LS0tLS1CRUdJTi...

# ============================================================
# Required Permissions for App-Only Auth
# ============================================================
# Grant these Application permissions in Azure AD (with admin consent):
# - Calendars.ReadWrite (read/write calendars for all users)
# - Mail.ReadWrite (read/write mail for all users)
# - User.Read.All (read user profiles)

# Note: Make sure to:
# 1. Copy this file to .env
# 2. Replace the placeholder values with your actual credentials
# 3. Add .env to .gitignore to keep your credentials secure